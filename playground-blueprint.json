{
  "$schema": "https://playground.wordpress.net/blueprint-schema.json",
  "landingPage": "/wp-admin/admin.php?page=atp-demo-shortcodes",
  "preferredVersions": {
    "php": "8.2",
    "wp": "latest"
  },
  "phpExtensionBundles": ["kitchen-sink"],
  "steps": [
    {
      "step": "login",
      "username": "admin",
      "password": "password"
    },
    {
      "step": "installPlugin",
      "pluginData": {
        "resource": "git:directory",
        "url": "https://github.com/mirror-factory/ATP-Demo",
        "ref": "refs/heads/claude/tier1-intake-form-uq7Mc",
        "path": "atp-demo-plugin"
      },
      "options": {
        "activate": true
      }
    },
    {
      "step": "setSiteOptions",
      "options": {
        "blogname": "ATP Demo",
        "blogdescription": "America Tracking Polls — Tier 1 Intake & Candidate Page System"
      }
    },
    {
      "step": "runPHP",
      "code": "<?php require '/wordpress/wp-load.php'; $content = '[atp_intake]'; $page_id = wp_insert_post(array('post_title' => 'Candidate Intake Form', 'post_content' => $content, 'post_status' => 'publish', 'post_type' => 'page')); update_post_meta($page_id, '_wp_page_template', 'elementor_canvas'); ?>"
    },
    {
      "step": "runPHP",
      "code": "<?php require '/wordpress/wp-load.php'; $content = \"[atp_cand_styles]\\n[atp_cand_nav]\\n[atp_cand_hero]\\n[atp_cand_stats]\\n[atp_cand_about]\\n[atp_cand_messages]\\n[atp_cand_issues]\\n[atp_cand_endorsements]\\n[atp_cand_video]\\n[atp_cand_volunteer]\\n[atp_cand_donate]\\n[atp_cand_social]\\n[atp_cand_footer]\"; $page_id = wp_insert_post(array('post_title' => 'Candidate Landing Page', 'post_content' => $content, 'post_status' => 'publish', 'post_type' => 'page')); ?>"
    }
  ]
}
